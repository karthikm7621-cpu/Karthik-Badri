{
  "name": "team-atk",
  "version": "1.0.0",
  "description": "Team ATK Flask backend with a vanilla JavaScript frontend.",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "prepare": "husky",
    "format": "biome format --write .",
    "format:check": "biome format --check .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "deadcode": "knip",
    "test": "jest --coverage --passWithNoTests",
    "test:ci": "jest --coverage --ci --passWithNoTests",
    "ci": "npm run check && npm run deadcode && npm run test:ci"
  },
  "lint-staged": {
    "*.{js,json,css,html,md,yml,yaml}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "knip": "^5.42.2",
    "lint-staged": "^15.2.10"
  }
}
